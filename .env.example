# Supabase project settings (Project Settings → API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Cloudflare Turnstile site key (dash.cloudflare.com → Turnstile → your site).
# This is the public site key, safe to expose in frontend code — NOT the
# secret key (that goes only in Supabase's Authentication > Bot and Abuse
# Protection settings). Optional: the login page skips CAPTCHA entirely if
# this is unset, same tolerant pattern as the Supabase env vars above.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
